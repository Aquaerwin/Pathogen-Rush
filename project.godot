; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="PATHOGEN RUSH"
run/main_scene="res://src/ui/mainMenu/LoadScreen.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="uid://5vu5r0gykdk7"
boot_splash/minimum_display_time=1500

[audio]

buses/default_bus_layout="uid://b3jmt7sqmny21"

[autoload]

Save="*res://src/core/autoload/Save.gd"
SceneTransition="*res://src/core/autoload/SceneTransition.gd"
AudioManager="*res://src/core/autoload/AudioManager.gd"

[display]

window/size/viewport_width=1366
window/size/viewport_height=768
window/size/mode=2
window/stretch/mode="canvas_items"

[gui]

theme/custom="res://assets/lainnya/MainTheme.tres"
theme/custom_font="uid://cyib4t7xf80n1"

[input_devices]

pointing/emulate_touch_from_mouse=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
