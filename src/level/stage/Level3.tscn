[sub_resource type="GDScript" id="GDScript_lc31b"]
script/source = "extends Node

@export var img_left_gap: float = 60.0
@export var img_top_gap: float = 144.0
@export var img_right_gap: float = 88.0
@export var img_bottom_gap: float = 48.0
@export var img_original_size: Vector2 = Vector2(1024, 576)
@export var screen_size: Vector2 = Vector2(1280, 720)

@export var grid_cols: int = 9
@export var grid_rows: int = 5

var occupied_cells = {}

func get_grid_start() -> Vector2:
	var scale_x = screen_size.x / img_original_size.x
	var scale_y = screen_size.y / img_original_size.y
	return Vector2(img_left_gap * scale_x, img_top_gap * scale_y)

func get_cell_size() -> Vector2:
	var scale_x = screen_size.x / img_original_size.x
	var scale_y = screen_size.y / img_original_size.y
	var grid_w = (img_original_size.x - img_left_gap - img_right_gap) * scale_x
	var grid_h = (img_original_size.y - img_top_gap - img_bottom_gap) * scale_y
	return Vector2(grid_w / float(grid_cols), grid_h / float(grid_rows))

func get_grid_index(pos: Vector2) -> Vector2:
	var cell_size = get_cell_size()
	var grid_start = get_grid_start()
	var col = int((pos.x - grid_start.x) / cell_size.x)
	var row = int((pos.y - grid_start.y) / cell_size.y)
	return Vector2(col, row)

func get_grid_center(grid_pos: Vector2) -> Vector2:
	var cell_size = get_cell_size()
	var grid_start = get_grid_start()
	var center_x = grid_start.x + (grid_pos.x * cell_size.x) + (cell_size.x / 2.0) + 15.0 # Geser 15px ke kanan
	var center_y = grid_start.y + (grid_pos.y * cell_size.y) + (cell_size.y / 2.0)
	return Vector2(center_x, center_y)

func is_cell_occupied(grid_pos: Vector2) -> bool:
	return occupied_cells.has(grid_pos)

func set_cell_occupied(grid_pos: Vector2, occupied: bool):
	if occupied:
		occupied_cells[grid_pos] = true
	else:
		occupied_cells.erase(grid_pos)

func is_valid_grid_pos(grid_pos: Vector2) -> bool:
	return grid_pos.x >= 0 and grid_pos.x < grid_cols and grid_pos.y >= 0 and grid_pos.y < grid_rows
"

